{
  "extends": "@dripl/typescript-config/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "composite": true,
    "noEmit": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "exactOptionalPropertyTypes": false
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/common" },
    { "path": "../../packages/db" }
  ]
}
