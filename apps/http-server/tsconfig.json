{
  "extends": "@dripl/typescript-config/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "exactOptionalPropertyTypes": false
  },
  "references": [
    { "path": "../../packages/common" },
    { "path": "../../packages/db" },
    { "path": "../../packages/utils" }
  ],
  "include": ["src/**/*"]
}
