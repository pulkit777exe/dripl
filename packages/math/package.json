{
  "name": "@dripl/math",
  "version": "0.0.0",
  "description": "Math utilities for geometry and intersection calculations",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./geometry": {
      "types": "./dist/geometry.d.ts",
      "default": "./dist/geometry.js"
    },
    "./hit-detection": {
      "types": "./dist/hit-detection.d.ts",
      "default": "./dist/hit-detection.js"
    },
    "./intersection": {
      "types": "./dist/intersection.d.ts",
      "default": "./dist/intersection.js"
    },
    "./performance": {
      "types": "./dist/performance.d.ts",
      "default": "./dist/performance.js"
    },
    "./constraints": {
      "types": "./dist/constraints.d.ts",
      "default": "./dist/constraints.js"
    }
  },
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dripl/common": "workspace:*"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
