{
  "name": "@dripl/common",
  "version": "0.0.0",
  "description": "Shared types, schemas, and utilities for Dripl",
  "license": "MIT",
  "main": "./dist/index",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./types/element": {
      "types": "./dist/types/element.d.ts",
      "default": "./dist/types/element.js"
    },
    "./types/user": {
      "types": "./dist/types/user.d.ts",
      "default": "./dist/types/user.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./scene": {
      "types": "./dist/scene.d.ts",
      "default": "./dist/scene.js"
    },
    "./pointer": {
      "types": "./dist/pointer.d.ts",
      "default": "./dist/pointer.js"
    },
    "./arrow-binding": {
      "types": "./dist/arrow-binding.d.ts",
      "default": "./dist/arrow-binding.js"
    },
    "./cascade-delete": {
      "types": "./dist/cascade-delete.d.ts",
      "default": "./dist/cascade-delete.js"
    }
  },
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
