{
  "name": "@dripl/element",
  "version": "0.0.0",
  "description": "Element factory and rendering for Dripl canvas",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./staticScene": {
      "types": "./dist/staticScene.d.ts",
      "default": "./dist/staticScene"
    },
    "./resizeElements": {
      "types": "./dist/resizeElements.d.ts",
      "default": "./dist/resizeElements"
    },
    "./renderElement": {
      "types": "./dist/renderElement.d.ts",
      "default": "./dist/renderElement"
    },
    "./shape-cache": {
      "types": "./dist/shape-cache.d.ts",
      "default": "./dist/shape-cache"
    }
  },
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dripl/common": "workspace:*",
    "@dripl/math": "workspace:*",
    "@dripl/utils": "workspace:*",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/test-utils": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
