{
  "name": "@dripl/test-utils",
  "version": "0.0.0",
  "description": "Shared test utilities for Dripl monorepo",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./elements": {
      "types": "./dist/elements.d.ts",
      "default": "./dist/elements.js"
    },
    "./users": {
      "types": "./dist/users.d.ts",
      "default": "./dist/users.js"
    },
    "./mock-canvas": {
      "types": "./dist/mock-canvas.d.ts",
      "default": "./dist/mock-canvas.js"
    }
  },
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dripl/common": "workspace:*"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
