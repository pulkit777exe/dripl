{
  "name": "@dripl/dripl",
  "version": "0.0.0",
  "description": "Core Dripl library with canvas, hooks, and state management",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*",
    "./styles": "./dist/styles/index.css"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint .",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@dripl/common": "workspace:*",
    "@dripl/eslint-config": "workspace:*",
    "@dripl/math": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "eslint": "^9.39.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "motion": "^12.25.0",
    "tailwind-merge": "^3.4.0",
    "@tanstack/store": "^0.8.0",
    "@tanstack/react-store": "^0.8.0",
    "zod": "^4.3.6",
    "uuid": "^13.0.0"
  }
}
