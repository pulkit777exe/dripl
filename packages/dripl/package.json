{
  "name": "@dripl/dripl",
  "version": "0.0.0",
  "description": "Core Dripl library with canvas, hooks, and state management",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index",
  "exports": {
    ".": "./dist/index",
    "./*": "./dist/*",
    "./styles": "./dist/styles/index.css"
  },
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint .",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@dripl/common": "workspace:*",
    "@dripl/math": "workspace:*",
    "@tanstack/react-store": "^0.8.1",
    "@tanstack/store": "^0.8.1",
    "clsx": "^2.1.1",
    "motion": "^12.40.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
