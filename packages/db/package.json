{
  "name": "@dripl/db",
  "version": "0.0.0",
  "description": "Database layer with Prisma ORM for Dripl",
  "license": "MIT",
  "private": true,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "pnpm run db:generate && tsc -b --force",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
