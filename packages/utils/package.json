{
  "name": "@dripl/utils",
  "version": "0.0.0",
  "description": "Utility functions for Dripl (encryption, storage, throttling)",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "default": "./dist/encryption/index"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env"
    }
  },
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dripl/common": "workspace:*"
  },
  "devDependencies": {
    "@dripl/eslint-config": "workspace:*",
    "@dripl/typescript-config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
