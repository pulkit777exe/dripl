{
  "name": "dripl",
  "private": true,
  "scripts": {
    "build": "pnpm run db:generate && pnpm -r --filter='@dripl/*' run build && turbo run build",
    "postinstall": "pnpm approve-builds --all",
    "db:generate": "prisma generate --schema=./packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=./packages/db/prisma/schema.prisma",
    "dev": "pnpm run db:generate && rm -rf apps/dripl-app/.next && turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "latest",
    "prettier": "latest",
    "prisma": "^7.0.1",
    "tsx": "^4.21.0",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ]
}
