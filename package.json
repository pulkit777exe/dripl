{
  "name": "dripl",
  "private": true,
  "scripts": {
    "build": "pnpm turbo run build",
    "postinstall": "pnpm approve-builds --all",
    "db:generate": "prisma generate --schema=./packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=./packages/db/prisma/schema.prisma",
    "dev": "pnpm run db:generate && rm -rf apps/dripl-app/.next && turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "boundaries": "turbo boundaries",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opensourceframework/next-pwa": "^5.6.3",
    "eslint": "latest",
    "prettier": "latest",
    "prisma": "^7.2.0",
    "tsx": "^4.20.6",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
