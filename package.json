{
  "name": "dripl",
  "private": true,
  "scripts": {
    "build": "pnpm turbo run build",
    "postinstall": "pnpm approve-builds",
    "db:generate": "prisma generate --schema=./packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=./packages/db/prisma/schema.prisma",
    "dev": "pnpm run db:generate && rm -rf apps/dripl-app/.next && turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "boundaries": "turbo boundaries",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "eslint": "^10.4.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "dependencies": {
    "compression": "^1.8.1"
  }
}
