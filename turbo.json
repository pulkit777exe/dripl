{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "JWT_SECRET",
    "PORT",
    "WS_PORT",
    "FRONTEND_URL",
    "REDIS_URL",
    "DATABASE_URL",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "env": [
        "JWT_SECRET",
        "PORT",
        "WS_PORT",
        "FRONTEND_URL",
        "REDIS_URL",
        "DATABASE_URL",
        "NODE_ENV"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"]
    }
  }
}
