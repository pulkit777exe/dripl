{
  "globalEnv": [
    "JWT_SECRET",
    "PORT",
    "WS_PORT",
    "FRONTEND_URL",
    "REDIS_URL",
    "DATABASE_URL",
    "NODE_ENV",
    "SMTP_USER",
    "SMTP_PASS",
    "GOOGLE_CLIENT_ID",
    "GEMINI_API_KEY",
    "DEBUG_PRISMA"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".turbo/**"]
    },
    "lint": {},
    "dev": {
      "persistent": true,
      "dependsOn": ["^build"],
      "env": [
        "JWT_SECRET",
        "PORT",
        "WS_PORT",
        "FRONTEND_URL",
        "REDIS_URL",
        "DATABASE_URL",
        "NODE_ENV"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"]
    }
  }
}
